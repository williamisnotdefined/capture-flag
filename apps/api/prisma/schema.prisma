generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String
  email                   String?                       @unique
  avatarUrl               String?                       @map("avatar_url")
  createdAt               DateTime                      @default(now()) @map("created_at")
  updatedAt               DateTime                      @updatedAt @map("updated_at")
  oauthAccounts           OAuthAccount[]
  sessions                Session[]
  organizationMemberships OrganizationMember[]
  projectMemberships      ProjectMember[]
  ownedFeatureFlags       FeatureFlag[]
  updatedFlagValues       FeatureFlagEnvironmentValue[]

  @@map("users")
}

model OAuthAccount {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  provider       String
  providerUserId String   @map("provider_user_id")
  providerEmail  String?  @map("provider_email")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

model Session {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Organization {
  id        String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String               @unique
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")
  members   OrganizationMember[]
  projects  Project[]

  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  role           String
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

model Project {
  id             String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String                        @map("organization_id") @db.Uuid
  name           String
  slug           String
  createdAt      DateTime                      @default(now()) @map("created_at")
  updatedAt      DateTime                      @updatedAt @map("updated_at")
  organization   Organization                  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        ProjectMember[]
  configs        Config[]
  environments   Environment[]
  states         ConfigEnvironmentState[]
  sdkKeys        SdkKey[]
  featureFlags   FeatureFlag[]
  flagValues     FeatureFlagEnvironmentValue[]

  @@unique([organizationId, slug])
  @@unique([id, organizationId])
  @@index([organizationId])
  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model Config {
  id           String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId    String                        @map("project_id") @db.Uuid
  key          String
  name         String
  description  String?
  createdAt    DateTime                      @default(now()) @map("created_at")
  updatedAt    DateTime                      @updatedAt @map("updated_at")
  project      Project                       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  states       ConfigEnvironmentState[]
  sdkKeys      SdkKey[]
  featureFlags FeatureFlag[]
  flagValues   FeatureFlagEnvironmentValue[]

  @@unique([projectId, key])
  @@unique([id, projectId])
  @@index([projectId])
  @@map("configs")
}

model Environment {
  id         String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String                        @map("project_id") @db.Uuid
  name       String
  key        String
  sortOrder  Int                           @map("sort_order")
  createdAt  DateTime                      @default(now()) @map("created_at")
  updatedAt  DateTime                      @updatedAt @map("updated_at")
  project    Project                       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  states     ConfigEnvironmentState[]
  sdkKeys    SdkKey[]
  flagValues FeatureFlagEnvironmentValue[]

  @@unique([projectId, key])
  @@unique([id, projectId])
  @@index([projectId])
  @@map("environments")
}

model ConfigEnvironmentState {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId     String      @map("project_id") @db.Uuid
  configId      String      @map("config_id") @db.Uuid
  environmentId String      @map("environment_id") @db.Uuid
  revision      Int         @default(1)
  etag          String
  generatedAt   DateTime    @map("generated_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  config        Config      @relation(fields: [configId, projectId], references: [id, projectId], onDelete: Cascade)
  environment   Environment @relation(fields: [environmentId, projectId], references: [id, projectId], onDelete: Cascade)

  @@unique([configId, environmentId])
  @@index([projectId, environmentId])
  @@index([etag])
  @@map("config_environment_states")
}

model SdkKey {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId     String      @map("project_id") @db.Uuid
  configId      String      @map("config_id") @db.Uuid
  environmentId String      @map("environment_id") @db.Uuid
  name          String
  keyPrefix     String      @map("key_prefix")
  keyHash       String      @unique @map("key_hash")
  revokedAt     DateTime?   @map("revoked_at")
  lastUsedAt    DateTime?   @map("last_used_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  config        Config      @relation(fields: [configId, projectId], references: [id, projectId], onDelete: Cascade)
  environment   Environment @relation(fields: [environmentId, projectId], references: [id, projectId], onDelete: Cascade)

  @@index([configId, environmentId])
  @@index([projectId, environmentId])
  @@index([keyPrefix])
  @@map("sdk_keys")
}

model FeatureFlag {
  id                String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId         String                        @map("project_id") @db.Uuid
  configId          String                        @map("config_id") @db.Uuid
  key               String
  name              String
  description       String?
  type              String
  tags              String[]                      @default([])
  hint              String?
  ownerUserId       String?                       @map("owner_user_id") @db.Uuid
  deletedAt         DateTime?                     @map("deleted_at")
  createdAt         DateTime                      @default(now()) @map("created_at")
  updatedAt         DateTime                      @updatedAt @map("updated_at")
  project           Project                       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  config            Config                        @relation(fields: [configId, projectId], references: [id, projectId], onDelete: Cascade)
  owner             User?                         @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  environmentValues FeatureFlagEnvironmentValue[]

  @@unique([configId, key])
  @@unique([id, projectId, configId])
  @@index([projectId, configId])
  @@index([ownerUserId])
  @@map("feature_flags")
}

model FeatureFlagEnvironmentValue {
  id                    String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId             String      @map("project_id") @db.Uuid
  configId              String      @map("config_id") @db.Uuid
  featureFlagId         String      @map("feature_flag_id") @db.Uuid
  environmentId         String      @map("environment_id") @db.Uuid
  defaultValue          Json        @map("default_value")
  rulesJson             Json        @default("[]") @map("rules_json")
  percentageAttribute   String      @default("identifier") @map("percentage_attribute")
  percentageOptionsJson Json        @default("[]") @map("percentage_options_json")
  updatedByUserId       String?     @map("updated_by_user_id") @db.Uuid
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")
  project               Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  config                Config      @relation(fields: [configId, projectId], references: [id, projectId], onDelete: Cascade)
  featureFlag           FeatureFlag @relation(fields: [featureFlagId, projectId, configId], references: [id, projectId, configId], onDelete: Cascade)
  environment           Environment @relation(fields: [environmentId, projectId], references: [id, projectId], onDelete: Cascade)
  updatedBy             User?       @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([featureFlagId, environmentId])
  @@index([configId, environmentId])
  @@index([projectId, environmentId])
  @@index([updatedByUserId])
  @@map("feature_flag_environment_values")
}
