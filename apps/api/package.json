{
  "name": "@capture-flag/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "node --env-file=../../.env.example --env-file-if-exists=../../.env --watch -r ts-node/register/transpile-only src/main.ts",
    "predev": "npm --workspace @capture-flag/shared run build",
    "prebuild": "npm --workspace @capture-flag/shared run build",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "test": "vitest run",
    "db:generate": "node --env-file=../../.env.example --env-file-if-exists=../../.env ../../node_modules/prisma/build/index.js generate",
    "db:migrate": "node --env-file=../../.env.example --env-file-if-exists=../../.env ../../node_modules/prisma/build/index.js migrate dev"
  },
  "dependencies": {
    "@capture-flag/shared": "^0.1.0",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "^5.22.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@types/supertest": "^6.0.2",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "vitest": "^2.1.4"
  }
}
